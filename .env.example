# Copy this file to .env for local development.
# Never commit real API keys or user-specific secrets.

# OpenAI transcription provider
# Required for saved recording transcription and dictation.
OPENAI_API_KEY=

# OpenAI API base URL. Keep the /v1 suffix unless using a compatible proxy.
OPENAI_API_BASE_URL=https://api.openai.com/v1

# Initial OpenAI transcription model used for saved recordings and dictation.
# The Settings tab can override this and persist the selected model.
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Venice provider
# Required for note generation.
VENICE_API_KEY=

# Venice API base URL. Keep the /api/v1 suffix unless using a compatible proxy.
VENICE_API_BASE_URL=https://api.venice.ai/api/v1

# Initial Venice transcription model available for saved recordings and dictation.
# The Settings tab can override this with either a Venice or OpenAI ASR model.
VENICE_TRANSCRIPTION_MODEL=nvidia/parakeet-tdt-0.6b-v3

# Initial Venice chat model used to turn transcripts and manual notes into
# generated note content. The Settings tab can override this and persist the
# selected model.
VENICE_GENERATION_MODEL=zai-org-glm-5

# Fast Venice text model used to polish dictation output from non-OpenAI ASR models.
# OpenAI ASR models use ASR prompting directly and skip this cleanup step.
VENICE_DICTATION_CLEANUP_MODEL=nvidia-nemotron-3-nano-30b-a3b

# Transcription language
# Optional ISO-639-1 language code passed to the active transcription provider.
# Example for Spanish: es
# Leave empty to let the provider auto-detect the spoken language.
OS_NOTETAKER_TRANSCRIPTION_LANGUAGE=
