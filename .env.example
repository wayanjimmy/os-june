# Copy this file to .env for local development.
# Never commit real API keys or user-specific secrets.

# Provider selection
# Valid values: openai, venice, mock.
# Leave empty for automatic selection:
# 1. openai when OPENAI_API_KEY is set
# 2. venice when VENICE_API_KEY is set
# 3. mock when no real provider key is available
# Mock mode is useful for offline recording/recovery checks, but it does not run
# real transcription, note generation, or dictation.
OS_NOTETAKER_PROVIDER=

# OpenAI provider
# Required when OS_NOTETAKER_PROVIDER=openai, or when relying on automatic
# selection and OpenAI should be the active provider.
OPENAI_API_KEY=

# OpenAI transcription model used for saved recordings and dictation.
OS_NOTETAKER_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# OpenAI text generation model used to turn transcripts and manual notes into
# generated note content.
OS_NOTETAKER_GENERATION_MODEL=gpt-5.2

# Venice provider
# Required when OS_NOTETAKER_PROVIDER=venice, or when relying on automatic
# selection and OPENAI_API_KEY is not set.
VENICE_API_KEY=

# Venice API base URL. Keep the /api/v1 suffix unless using a compatible proxy.
VENICE_API_BASE_URL=https://api.venice.ai/api/v1

# Venice transcription model used for saved recordings and dictation.
VENICE_TRANSCRIPTION_MODEL=nvidia/parakeet-tdt-0.6b-v3

# Venice chat model used to turn transcripts and manual notes into generated
# note content.
VENICE_GENERATION_MODEL=zai-org-glm-5

# Transcription language
# Optional ISO-639-1 language code passed to the active transcription provider.
# Example for Spanish: es
# Leave empty to let the provider auto-detect the spoken language.
OS_NOTETAKER_TRANSCRIPTION_LANGUAGE=
