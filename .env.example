# Copy this file to .env for local development.
# Never commit real API keys or user-specific secrets.

# --- June API -------------------------------------------------------------
# Local development default is http://127.0.0.1:8080 when unset.
# Staging is https://june-api-staging.opensoftware.co.
JUNE_API_URL=http://127.0.0.1:8080

# Open source local mode. The desktop app uses this bearer token instead of
# requiring Login with OpenSoftware. Keep it in sync with june-api/.env.
OS_JUNE_LOCAL_DEV=1
OS_JUNE_LOCAL_DEV_BEARER_TOKEN=local-dev-token
OS_JUNE_LOCAL_DEV_USER_ID=usr_local_dev

# Fast Venice text model used for short automatic note title suggestions.
# Falls back to VENICE_DICTATION_CLEANUP_MODEL when unset.
VENICE_TITLE_SUGGESTION_MODEL=nvidia-nemotron-3-nano-30b-a3b

# Transcription language
# Optional ISO-639-1 language code passed through note processing where supported.
# Example for Spanish: es
OS_NOTETAKER_TRANSCRIPTION_LANGUAGE=

# Initial transcription model available for saved recordings and dictation.
# The Settings tab can override this with any model returned by June API.
VENICE_TRANSCRIPTION_MODEL=nvidia/parakeet-tdt-0.6b-v3
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Initial chat model used to turn transcripts and manual notes into generated note content.
# The Settings tab can override this with any text model returned by June API.
VENICE_GENERATION_MODEL=zai-org-glm-5-2

# --- OS Accounts (Login with Open Software) ---------------------------------
# Optional when OS_JUNE_LOCAL_DEV=1. Identity only in the desktop app.
# The App API key (osk_) is server-side only in June API and never belongs
# in this file.
# Staging example:
#   OS_ACCOUNTS_URL=https://os-accounts-portal-staging.up.railway.app
#   OS_ACCOUNTS_API_URL=https://os-accounts-api-staging.up.railway.app
# `make dev-staging` overrides both URLs. Set the staging OS_ACCOUNTS_CLIENT_ID
# (format: ocl_...) here or in the shell for login to work.
# Set OS_JUNE_DEV_PLAINTEXT_TOKEN_STORE=1 to avoid repeated Keychain prompts in dev.
OS_ACCOUNTS_URL=
OS_ACCOUNTS_API_URL=
# OAuth client id issued by the OS Accounts admin console (format: ocl_...).
# Sent on the /login URL so OS Accounts can identify June.
OS_ACCOUNTS_CLIENT_ID=
# Loopback port for the login redirect. Must match the redirect_uri allowlisted
# at registration: http://127.0.0.1:<port>/callback (default 8765).
OS_ACCOUNTS_LOOPBACK_PORT=
# Local dev only: set to 1 in debug builds to avoid macOS Keychain prompts.
# Stores OS Accounts access/refresh tokens in src-tauri/target/dev-os-accounts-tokens.json
# (and Google connector tokens in src-tauri/target/dev-google-connector-tokens.json).
OS_JUNE_DEV_PLAINTEXT_TOKEN_STORE=0

# --- Private connectors (Google) ---------------------------------------------
# Credentials of the Google Cloud "Desktop app" client used by the
# Gmail/Calendar connectors. Google requires both values at its token endpoint.
# A desktop app cannot keep the client secret confidential (it ships in the
# binary), so PKCE still protects the authorization-code exchange and user
# refresh/access tokens remain the actual secrets. Leave either value empty to
# disable connecting accounts (listing still works).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
