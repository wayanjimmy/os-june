{
  "manifest_version": 3,
  "name": "June",
  "version": "0.1.0",
  "description": "Connects June to this browser so the agent can work in visibly marked tabs you approve.",
  "key": "",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "June",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "permissions": ["nativeMessaging", "tabs", "tabGroups", "debugger"]
}
