# June API local env. Copy to june-api/.env and fill in real values.
# This file lives next to the backend crate so server-only secrets stay
# isolated from the Tauri client's env at the repo root.
#
# Figment maps JUNE__SECTION__FIELD env vars onto AppConfig fields. The
# double underscore (__) is the section separator — single underscores in
# field names stay literal (e.g. APP_API_KEY -> app_api_key).

# --- Open source local mode -------------------------------------------------
# Enabled by default so a cloned repo can run without OS Accounts or billing.
# Keep the bearer token in sync with OS_JUNE_LOCAL_DEV_BEARER_TOKEN in the
# root .env file.
#
# WARNING: the default bearer token below is a publicly known placeholder. That
# is safe only while JUNE__SERVER__HOST stays on loopback (127.0.0.0/8 or ::1).
# If you rebind the server to a non-loopback address, anyone who can reach the
# port can authenticate with this token (local mode also skips metering), and
# June API refuses to start in that combination. Set a random token instead,
# e.g. `openssl rand -hex 32`, and keep it in sync with the root .env.
JUNE__SERVER__HOST=127.0.0.1
JUNE__LOCAL_DEV__ENABLED=true
JUNE__LOCAL_DEV__BEARER_TOKEN=local-dev-token
JUNE__LOCAL_DEV__USER_ID=usr_local_dev

# --- OS Accounts ------------------------------------------------------------
# Optional when JUNE__LOCAL_DEV__ENABLED=true. Disable local mode and fill
# these in for a connected deployment with token verification and metering.
# Local OS Accounts example: http://127.0.0.1:3000
# Staging example: https://os-accounts-api-staging.up.railway.app
JUNE__OS_ACCOUNTS__API_URL=

# Per-app secret issued by the OS Accounts admin console. Server-side only.
# Never embed in the desktop binary or the root .env file.
JUNE__OS_ACCOUNTS__APP_API_KEY=

# Optional service token used only for anonymous P3A aggregate ingestion into
# OS Accounts. Server-side only; OS Accounts stores the SHA-256 hash. When
# unset, P3A ingest is disabled and reports are logged only.
JUNE__OS_ACCOUNTS__P3A_INGEST_TOKEN=

# Flat credit Hold authorized for every metered action (transcribe, generate,
# dictate). Skips per-request estimation entirely — the duration probe and
# token pre-count are bypassed in favor of this single value. Trades a bigger
# Hold for not needing to support every audio format the helper might produce.
# Default: 250.
# JUNE__OS_ACCOUNTS__FLAT_ESTIMATE_CREDITS=250

# --- Upstream providers -----------------------------------------------------
# In local mode, June API exposes only models whose provider has a usable
# key. Fill Venice for the default text, dictation, and private transcription
# models. Fill OpenAI only if you want the default OpenAI transcription model.
# To use a compatible provider, set the matching BASE_URL and add pricing
# entries in config.toml for the model ids you want to expose.
JUNE__UPSTREAMS__OPENAI__API_KEY=
# JUNE__UPSTREAMS__OPENAI__BASE_URL=https://api.openai.com/v1
JUNE__UPSTREAMS__VENICE__API_KEY=VENICE_API_KEY_REPLACE_ME
# JUNE__UPSTREAMS__VENICE__BASE_URL=https://api.venice.ai/api/v1
# OpenSoftware private-router canary: https://api.opensoftware.co/v1

# --- Issue reports ----------------------------------------------------------
# Optional. The destination is fixed in config.toml: the `june` project in the
# `open-software` org on os-platform. Set the bot user's fellow API key to file
# reports as Issues.
# Without it, reports are accepted but logged only.
# JUNE__ISSUE_REPORTS__OS_PLATFORM_API_KEY=
