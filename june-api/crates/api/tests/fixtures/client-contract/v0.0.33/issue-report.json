{
  "description": "submit_issue_report: streamed issue report with attachment",
  "endpoint": "/v1/issue-reports",
  "multipart": [
    {
      "name": "description",
      "value": "Recording stops after two minutes."
    },
    {
      "name": "appVersion",
      "value": "0.0.33"
    },
    {
      "name": "platform",
      "value": "macos"
    },
    {
      "name": "stream",
      "value": "true"
    },
    {
      "name": "category",
      "value": "bug"
    },
    {
      "name": "sessionId",
      "value": "sess-fixture-1"
    },
    {
      "name": "agentDiagnosis",
      "value": "Repro: start a recording, wait two minutes."
    },
    {
      "name": "attachmentName",
      "value": "log.txt"
    },
    {
      "name": "attachment",
      "value": "log line one",
      "filename": "log.txt",
      "contentType": "text/plain"
    }
  ],
  "expect": {
    "sse": true,
    "requiredDataFields": [
      "received:boolean"
    ]
