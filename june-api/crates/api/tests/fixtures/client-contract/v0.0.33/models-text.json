{
  "description": "list_models: text model catalog; every field the client ModelDto requires",
  "endpoint": "/v1/models?type=text",
  "auth": false,
  "expect": {
    "requiredItemFields": [
      "provider:string",
      "id:string",
      "name:string",
      "modelType:string",
      "traits:array",
      "capabilities:array",
      "priceUnit:string",
      "priceDescription:string"
    ]
  }
}
