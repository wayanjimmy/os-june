{
  "description": "video_status: poll a completed non-VPS job; the raw video bytes stream inline with the video mime type",
  "endpoint": "/v1/video/status/{jobId}",
  "setup": {
    "endpoint": "/v1/video/generate",
    "body": {
      "prompt": "Waves at sunset, inline",
      "model": "wan-2.2-a14b-text-to-video",
      "requestId": "req-video-completed-inline-1",
      "duration": "5"
    },
    "pathVar": "jobId"
  },
  "expect": {
    "envelope": false,
    "rawText": "fake-mp4-bytes",
    "contentType": "video/mp4"
  }
}
