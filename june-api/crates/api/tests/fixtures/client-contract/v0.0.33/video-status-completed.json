{
  "description": "video_status: poll a job that completed; the VPS-backed completed status shape",
  "endpoint": "/v1/video/status/{jobId}",
  "setup": {
    "endpoint": "/v1/video/generate",
    "body": {
      "prompt": "Waves at sunset, instantly",
      "model": "wan-2.2-a14b-text-to-video",
      "requestId": "req-video-completed-1",
      "duration": "5"
    },
    "pathVar": "jobId"
  },
  "expect": {
    "requiredDataFields": [
      "status:string",
      "downloadUrl:string",
      "mimeType:string",
      "model:string",
      "provider:string"
    ]
  }
}
