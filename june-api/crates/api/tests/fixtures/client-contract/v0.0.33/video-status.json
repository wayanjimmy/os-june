{
  "description": "video_status: poll a job the client just queued; processing status shape",
  "endpoint": "/v1/video/status/{jobId}",
  "setup": {
    "endpoint": "/v1/video/generate",
    "body": {
      "prompt": "Waves at sunset",
      "model": "wan-2.2-a14b-text-to-video",
      "requestId": "req-video-status-1",
      "duration": "5"
    },
    "pathVar": "jobId"
  },
  "expect": {
    "requiredDataFields": [
      "status:string",
      "averageExecutionMs:number",
      "executionMs:number"
    ]
  }
}
