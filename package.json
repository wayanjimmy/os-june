{
  "name": "os-june",
  "version": "0.0.32",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "tauri": "tauri",
    "tauri:dev": "node scripts/tauri-dev.mjs",
    "tauri:build": "node scripts/tauri-build.mjs",
    "tauri:build:signed-dmg": "./scripts/build-signed-dmg.sh",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest run",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml --locked",
    "test:rust:coverage": "cargo llvm-cov --manifest-path src-tauri/Cargo.toml --all-targets --html --output-dir src-tauri/target/llvm-cov/html",
    "test:june-api": "cd june-api && cargo test --all-targets --all-features --locked -- --test-threads=1",
    "test:june-api:coverage": "cd june-api && cargo llvm-cov --workspace --all-features --html --output-dir target/llvm-cov/html",
    "test:hermes-smoke": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/hermes-smoke.ts",
    "hermes:upgrade-check": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/hermes-upgrade-check.ts",
    "version:bump": "node scripts/bump-version.mjs",
    "icons": "node scripts/generate-icons.mjs",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-three/drei": "^9",
    "@react-three/fiber": "^8",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@tiptap/extension-mention": "3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/pm": "3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@tiptap/suggestion": "3.27.1",
    "border-beam": "^1.2.0",
    "central-icons": "npm:@central-icons-react/round-outlined-radius-3-stroke-2@1.1.233",
    "central-icons-filled": "npm:@central-icons-react/round-filled-radius-3-stroke-2@1.1.241",
    "framer-motion": "^12.40.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^2.0.7",
    "three": "^0.185.1",
    "three-stdlib": "^2.36.1",
    "unicode-animations": "^1.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@tauri-apps/cli": "^2.11.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.185",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "agentation": "^3.0.2",
    "jsdom": "^25.0.1",
    "playwright": "^1.61.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
