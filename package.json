{
  "name": "os-scribe",
  "version": "0.0.20",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "tauri": "tauri",
    "tauri:dev": "node scripts/tauri-dev.mjs",
    "tauri:build": "node scripts/tauri-build.mjs",
    "tauri:build:signed-dmg": "./scripts/build-signed-dmg.sh",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest run",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:rust:coverage": "cargo llvm-cov --manifest-path src-tauri/Cargo.toml --all-targets --html --output-dir src-tauri/target/llvm-cov/html",
    "test:scribe-api": "cd scribe-api && cargo test --all-targets --all-features --locked -- --test-threads=1",
    "test:scribe-api:coverage": "cd scribe-api && cargo llvm-cov --workspace --all-features --html --output-dir target/llvm-cov/html",
    "test:hermes-smoke": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/hermes-smoke.ts",
    "hermes:upgrade-check": "node --disable-warning=ExperimentalWarning --experimental-strip-types scripts/hermes-upgrade-check.ts",
    "version:bump": "node scripts/bump-version.mjs",
    "lint": "tsc --noEmit",
    "format": "prettier --check \"src/**/*.{ts,tsx,css}\" \"src-tauri/tauri*.conf.json\" \"package.json\" \"tsconfig.json\" \"vite.config.ts\" \"index.html\" \"README.md\""
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@tiptap/extension-mention": "3.23.5",
    "@tiptap/extension-placeholder": "^3.23.5",
    "@tiptap/pm": "3.23.5",
    "@tiptap/react": "^3.23.5",
    "@tiptap/starter-kit": "^3.27.1",
    "@tiptap/suggestion": "3.23.5",
    "border-beam": "^1.2.0",
    "central-icons": "npm:@central-icons-react/round-outlined-radius-3-stroke-2@1.1.233",
    "central-icons-filled": "npm:@central-icons-react/round-filled-radius-3-stroke-2@1.1.241",
    "framer-motion": "^12.40.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "unicode-animations": "^1.0.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "agentation": "^3.0.2",
    "jsdom": "^25.0.1",
    "prettier": "^3.8.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "neverBuiltDependencies": [
      "@central-icons-react/round-outlined-radius-3-stroke-2",
      "@central-icons-react/round-filled-radius-3-stroke-2"
    ]
  }
}
