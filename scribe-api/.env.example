# Scribe API local env. Copy to scribe-api/.env and fill in real values.
# This file lives next to the backend crate so server-only secrets stay
# isolated from the Tauri client's env at the repo root.
#
# Figment maps SCRIBE__SECTION__FIELD env vars onto AppConfig fields. The
# double underscore (__) is the section separator — single underscores in
# field names stay literal (e.g. APP_API_KEY -> app_api_key).

# --- Open source local mode -------------------------------------------------
# Enabled by default so a cloned repo can run without OS Accounts or billing.
# Keep the bearer token in sync with OS_SCRIBE_LOCAL_DEV_BEARER_TOKEN in the
# root .env file.
SCRIBE__SERVER__HOST=127.0.0.1
SCRIBE__LOCAL_DEV__ENABLED=true
SCRIBE__LOCAL_DEV__BEARER_TOKEN=local-dev-token
SCRIBE__LOCAL_DEV__USER_ID=usr_local_dev

# --- OS Accounts ------------------------------------------------------------
# Optional when SCRIBE__LOCAL_DEV__ENABLED=true. Disable local mode and fill
# these in for a connected deployment with token verification and metering.
# Local OS Accounts example: http://127.0.0.1:3000
# Staging example: https://os-accounts-api-staging.up.railway.app
SCRIBE__OS_ACCOUNTS__API_URL=

# Per-app secret issued by the OS Accounts admin console. Server-side only.
# Never embed in the desktop binary or the root .env file.
SCRIBE__OS_ACCOUNTS__APP_API_KEY=

# Flat credit Hold authorized for every metered action (transcribe, generate,
# dictate). Skips per-request estimation entirely — the duration probe and
# token pre-count are bypassed in favor of this single value. Trades a bigger
# Hold for not needing to support every audio format the helper might produce.
# Default: 250.
# SCRIBE__OS_ACCOUNTS__FLAT_ESTIMATE_CREDITS=250

# --- Upstream providers -----------------------------------------------------
# In local mode, Scribe API exposes only models whose provider has a usable
# key. Fill Venice for the default text, dictation, and private transcription
# models. Fill OpenAI only if you want the default OpenAI transcription model.
# To use a compatible provider, set the matching BASE_URL and add pricing
# entries in config.toml for the model ids you want to expose.
SCRIBE__UPSTREAMS__OPENAI__API_KEY=
# SCRIBE__UPSTREAMS__OPENAI__BASE_URL=https://api.openai.com/v1
SCRIBE__UPSTREAMS__VENICE__API_KEY=VENICE_API_KEY_REPLACE_ME
# SCRIBE__UPSTREAMS__VENICE__BASE_URL=https://api.venice.ai/api/v1

# --- Issue reports ----------------------------------------------------------
# Optional. The destination is fixed in config.toml: open-software/june on
# os-platform. Set the bot user's fellow API key to file reports as Issues.
# Without it, reports are accepted but logged only.
# SCRIBE__ISSUE_REPORTS__OS_PLATFORM_API_KEY=
