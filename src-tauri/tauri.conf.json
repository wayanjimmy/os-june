{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OS Scribe",
  "version": "0.1.0",
  "identifier": "co.opensoftware.scribe",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build",
    "devUrl": "http://127.0.0.1:1421",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "OS Scribe",
        "width": 1180,
        "height": 780,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": false
      },
      {
        "label": "hud",
        "url": "/hud.html",
        "title": "OS Scribe Dictation",
        "width": 220,
        "height": 120,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "focusable": false,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' asset: data:; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:*; media-src 'self' asset: data:; object-src 'none'; base-uri 'none'; frame-ancestors 'none'",
      "capabilities": ["main", "hud"]
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [
        {
          "scheme": ["osscribe"],
          "appLink": false
        }
      ],
      "desktop": {
        "schemes": ["osscribe"]
      }
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "targets": ["app", "dmg"],
    "resources": {
      "../.tauri-helper/OS Scribe.app": "native/bin/OS Scribe.app",
      "../.tauri-helper/OS Scribe Dictation Helper.app": "native/bin/OS Scribe Dictation Helper.app"
    },
    "macOS": {
      "bundleName": "OS Scribe",
      "entitlements": "Entitlements.plist",
      "exceptionDomain": "",
      "frameworks": [],
      "infoPlist": "Info.plist"
    }
  }
}
